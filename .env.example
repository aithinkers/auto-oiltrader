# Copy to .env and fill in. NEVER commit .env.

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# IB connection (matches config/settings.toml [ib] section)
IB_HOST=127.0.0.1
IB_PORT=7496
IB_CLIENT_ID=100
IB_ACCOUNT=

# Notification provider (ntfy is default)
NTFY_TOPIC=replace-with-private-topic-name
NTFY_SERVER=https://ntfy.sh

# Optional: Pushover (if you choose pushover instead of ntfy)
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Database
TRADER_DB_PATH=./data/trader.db
SNAPSHOT_DIR=./data/snapshots

# Misc
LOG_LEVEL=INFO
TZ=America/New_York
